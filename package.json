{
  "name": "postgres-pool",
  "version": "12.0.0",
  "description": "Node postgres connection pool implementation for node-pg",
  "keywords": [
    "connection",
    "node",
    "pg",
    "pool",
    "pooling",
    "postgres"
  ],
  "homepage": "https://github.com/postgres-pool/postgres-pool#readme",
  "bugs": {
    "url": "https://github.com/postgres-pool/postgres-pool/issues"
  },
  "license": "MIT",
  "author": "Jim Geurts <jim@biacreations.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/postgres-pool/postgres-pool.git"
  },
  "files": [
    "certs",
    "dist",
    "src",
    "!**/*.test.ts"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack && cp -R certs dist",
    "test": "pnpm run test:types && vp test run",
    "test:types": "tsc --noEmit --skipLibCheck",
    "format": "vp fmt",
    "lint:code": "vp lint --fix --fix-suggestions --deny-warnings",
    "lint:markdown": "markdownlint '*.md' '!(node_modules|dist)/**/*.md' --config=.github/linters/.markdown-lint.yml --fix",
    "lint": "pnpm run format && run-p lint:*",
    "lint-staged": "lint-staged",
    "docker:up": "docker-compose -f .devcontainer/docker-compose.yml up -d",
    "docker:down": "docker-compose -f .devcontainer/docker-compose.yml down",
    "beta": "pnpm publish --tag beta --no-git-checks",
    "prepublishOnly": "pinst --disable",
    "postpublish": "pinst --enable",
    "prepare": "husky"
  },
  "devDependencies": {
    "@faker-js/faker": "10.5.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.9",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": ">=22",
    "@types/pg": "8.20.0",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint-config-decent": "4.2.38",
    "eslint-plugin-jsdoc": "63.1.0",
    "eslint-plugin-security": "4.0.1",
    "eslint-plugin-unicorn": "72.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "markdownlint-cli": "0.49.1",
    "npm-run-all2": "9.0.2",
    "oxlint": "1.72.0",
    "oxlint-plugin-eslint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "pg": "8.22.0",
    "pinst": "3.0.0",
    "semantic-release": "25.0.8",
    "strict-event-emitter-types": "2.0.0",
    "typescript": "7.0.2",
    "vite-plus": "0.2.4",
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "pg": "^8.0.0"
  },
  "lint-staged": {
    "*.md": [
      "vp fmt --no-error-on-unmatched-pattern",
      "markdownlint --config=.github/linters/.markdown-lint.yml --fix"
    ],
    "*.{js,cjs,mjs,ts}": [
      "vp fmt --no-error-on-unmatched-pattern",
      "vp lint --fix --fix-suggestions --deny-warnings"
    ],
    "*.{json,json5,yml,yaml}": [
      "vp fmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578"
}
